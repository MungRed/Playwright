{
  "title": "银河铁道之夜",
  "description": "改编自宫泽贤治《银河铁道之夜》，以乔瓦尼的视角踏上银河列车，在星光与离别中探寻生命与幸福的意义。",
  "segments": [
    {
      "id": "s1",
      "speaker": "",
      "text": "",
      "effect": "typewriter",
      "speed": 55,
      "next": "s2",
